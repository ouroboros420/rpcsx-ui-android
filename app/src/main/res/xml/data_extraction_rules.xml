<?xml version="1.0" encoding="utf-8"?>
<!-- Used by android:dataExtractionRules (API >= 31). -->
<data-extraction-rules>
    <cloud-backup>
        <!-- RPCN credentials: never leave the device via cloud backup. -->
        <exclude domain="file" path="config/rpcn.yml"/>
    </cloud-backup>
    <device-transfer>
        <!-- RPCN credentials: never copied during device-to-device transfer. -->
        <exclude domain="file" path="config/rpcn.yml"/>
    </device-transfer>
</data-extraction-rules>
